import java.io.File;
import java.io.IOException;
import java.io.RandomAccessFile;

public class MusicManagement {
	private int totalSong;
	private RandomAccessFile raf;

	private static final int NAME_SIZE = 25;

	public MusicManagement(File file) throws IOException {
		this.raf = new RandomAccessFile(file, "rw");
		if (raf.length() > 0) {
			totalSong = raf.readInt();
		} else {
			totalSong = 0;
			raf.writeInt(totalSong);
		}
	}

	public void addSong(Song song) throws IOException {
		raf.seek(raf.length());
		song.write(raf, NAME_SIZE);
		totalSong++;
		raf.seek(0);
		raf.writeInt(totalSong);
	}

	public boolean delete(String name) throws IOException {
		for (int i = 0; i < totalSong; i++) {
			int pos = 4 + i * (1 + 1 + 50 + 4);
			raf.seek(pos);
			Song song = new Song();
			if (song.delete(raf, name, NAME_SIZE)) {
				return true;
			}
		}
		return false;
	}
}
