import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.rmi.NotBoundException;
import java.rmi.registry.LocateRegistry;
import java.rmi.registry.Registry;
import java.util.StringTokenizer;

public class Client {
	public static void main(String[] args) throws NotBoundException, IOException {
		Registry reg = LocateRegistry.getRegistry(1099);

		IUser user = (IUser) reg.lookup("user");
		boolean isLogin = false;
		String lastUserName = null;
		User lastUser = null;
		BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
		while (!isLogin) {
			String line = br.readLine();
			if (line.equalsIgnoreCase("QUIT")) {
				br.close();
				System.out.println("Bye");
				break;
			}
			StringTokenizer st = new StringTokenizer(line, " ");
			String cmd = st.nextToken().toUpperCase();
			String param = st.hasMoreTokens() ? st.nextToken() : "";
			if (cmd.equalsIgnoreCase("USER")) {
				if (!user.checkUser(param)) {
					System.out.println("ERROR");
					continue;
				}
				lastUserName = param;
			}
			if (cmd.equalsIgnoreCase("PASSWORD")) {
				if (lastUserName == null) {
					System.out.println("Dang nhap truoc");
					continue;
				} else if (user.login(lastUserName, param) == null) {
					System.out.println("ERROR");
					continue;
				} else {
					isLogin = true;
					lastUser = user.login(lastUserName, param);
				}
			}
		}
		while (isLogin) {
			ITransactionLog transactionLog = (ITransactionLog) reg.lookup("transactionLog");
			String line = br.readLine();
			if (line.equalsIgnoreCase("QUIT")) {
				br.close();
				System.out.println("Bye");
				break;
			}
			StringTokenizer st = new StringTokenizer(line, " ");
			String cmd = st.nextToken().toUpperCase();
			String param = st.hasMoreTokens() ? st.nextToken() : "";
			switch (cmd) {
			case "DEPOSIT": {
				transactionLog.deposit(lastUser.getStk(), param);
			}
			default:
				throw new IllegalArgumentException("Unexpected value: " + cmd);
			}
		}
	}
}
