import java.io.File;
import java.io.IOException;
import java.io.RandomAccessFile;
import java.util.ArrayList;
import java.util.List;

public class MusicManagement {
	private int totalSong;
	private RandomAccessFile raf;

	private static final int NAME_SIZE = 25;

	public MusicManagement(File file) throws IOException {
		this.raf = new RandomAccessFile(file, "rw");
		if (raf.length() > 0) {
			totalSong = raf.readInt();
		} else {
			totalSong = 0;
			raf.writeInt(totalSong);
		}
	}

	public void addSong(Song song) throws IOException {
		raf.seek(raf.length());
		song.write(raf, NAME_SIZE);
		totalSong++;
		raf.seek(0);
		raf.writeInt(totalSong);
	}

	public boolean delete(String name) throws IOException {
		for (int i = 0; i < totalSong; i++) {
			int pos = 4 + i * (1 + 1 + 50 + 4);
			raf.seek(pos);
			Song song = new Song();
			if (song.delete(raf, name, NAME_SIZE)) {
				return true;
			}
		}
		return false;
	}

	public List<Song> list() throws IOException {
		List<Song> result = new ArrayList<Song>();
		for (int i = 0; i < totalSong; i++) {
			int pos = 4 + i * (1 + 1 + 50 + 4);
			raf.seek(pos);
			if (!raf.readBoolean()) {
				Song song = new Song();
				song.read(raf, NAME_SIZE);
				result.add(song);
			}
		}
		return result;
	}

	public Song get(int index) throws IOException {
		if (index > totalSong || index < 0) {
			return null;
		}
		int pos = 4 + index * (1 + 1 + 50 + 4);
		raf.seek(pos);
		if (raf.readBoolean()) {
			return null;
		}
		Song song = new Song();
		song.read(raf, NAME_SIZE);
		return song;
	}

	public boolean update(int index, Song newSong) throws IOException {
		if (index > totalSong || index < 0) {
			return false;
		}
		int pos = 4 + index * (1 + 1 + 50 + 4);
		raf.seek(pos);
		newSong.write(raf, NAME_SIZE);
		return true;
	}

	public static void main(String[] args) throws IOException {
		MusicManagement mm = new MusicManagement(new File("D:\\PlayList.data"));
		final byte POP = 1;
		mm.addSong(new Song(POP, "Hehe", 25));
		System.out.println(mm.list());
	}
}
