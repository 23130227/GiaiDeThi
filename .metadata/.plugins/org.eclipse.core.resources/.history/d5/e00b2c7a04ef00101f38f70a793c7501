import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.util.ArrayList;
import java.util.List;

public class DAO {
	private Connection connection;

	public DAO() throws SQLException {
		this.connection = DriverManager.getConnection("jdbc:ucanaccess://D:/De20242025_TCP");
	}

	public boolean checkProductExist(int productID) throws SQLException {
		String sql = "SELECT * FROM products WHERE product_id = ?";
		PreparedStatement ps = connection.prepareStatement(sql);
		ResultSet rs = ps.executeQuery();
		return rs.next();
	}

	public boolean add(int productID, String name, int count, double price) throws SQLException {
		String sql = "INSERT INTO products VALUES (?,?,?,?)";
		PreparedStatement pr = connection.prepareStatement(sql);
		pr.setInt(1, productID);
		pr.setString(2, name);
		pr.setInt(3, count);
		pr.setDouble(4, price);
		return pr.executeUpdate() > 0;
	}

	public boolean buySingleProduct(int productID) throws SQLException {
		if (!checkProductExist(productID)) {
			return false;
		}
		String sql = "UPDATE products SET count = count - 1 WHERE product_id = ?";
		PreparedStatement ps = connection.prepareStatement(sql);
		ps.setInt(1, productID);
		return ps.executeUpdate() > 0;
	}

	public boolean buy(List<Integer> productIDList) throws SQLException {
		for (int i = 0; i < productIDList.size(); i++) {
			if (!buySingleProduct(productIDList.get(i))) {
				return false;
			}
		}
		return true;
	}

	public List<Product> price(double fromPrice, double toPrice) throws SQLException {
		List<Product> result = new ArrayList<Product>();
		String sql = "SELECT * FROM products WHERE price BETWEEN ? AND ?";
		PreparedStatement ps = connection.prepareStatement(sql);
		ps.setDouble(1, fromPrice);
		ps.setDouble(2, toPrice);
		ResultSet rs = ps.executeQuery();
		while (rs.next()) {
			Product product = new Product(rs.getInt("product_id"), rs.getString("name"), rs.getInt("count"),
					rs.getDouble("price"));
			result.add(product);
		}
		return result;
	}

	public List<Product> name(String name) throws SQLException {
		List<Product> result = new ArrayList<Product>();
		String sql = "SELECT * FROM products WHERE name LIKE ?";
		PreparedStatement ps = connection.prepareStatement(sql);
		ps.setString(1, "%" + name + "%");
		ResultSet rs = ps.executeQuery();
		while (rs.next()) {
			Product product = new Product(rs.getInt("product_id"), rs.getString("name"), rs.getInt("count"),
					rs.getDouble("price"));
			result.add(product);
		}
		return result;
	}
}
